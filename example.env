# Discord Bot Token (Required for Discord Bot client login)
TOKEN=YOUR_DISCORD_BOT_TOKEN

# Discord Application Credentials (Required for OAuth2 Login dashboard)
# Find these on: https://discord.com/developers/applications
CLIENT_ID=YOUR_DISCORD_CLIENT_ID
CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET
REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session security (Random string used to sign cookie sessions)
SESSION_SECRET=some_long_random_cookie_secret_string

# Express server listening port
PORT=3000

# MariaDB / MySQL Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_DATABASE=antibot_db
